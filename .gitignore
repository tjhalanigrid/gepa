# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Caches
.pytest_cache/
.coverage
htmlcov/

# Virtual Environments
venv/
.venv/
env/

# Environment variables — never commit credentials
.env
.env.*
!.env.example

# IDE files
.vscode/
.idea/
.DS_Store

# Heavy ML Weights (directory structure is tracked via .gitkeep)
**/weights/*.pt
**/weights/*.pth
**/weights/*.bin
**/weights/*.onnx

# Temporary VLM optimized image directories
**/temp_optimized/

# Local database caches & user data uploads
backend/uploads/*
!backend/uploads/.gitkeep
postgres_data/
mongo_data/

# Temporary run outputs and JSON claims reports
experiments/outputs*/
data/synthetic/*.csv
/experiments/
/datasets/
